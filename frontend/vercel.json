{
  "buildCommand": "npm run build:test",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://tradesupport.onrender.com",
    "VITE_WS_URL": "wss://tradesupport.onrender.com/ws"
  }
}